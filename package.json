{
  "name": "cv-generator-life-map",
  "version": "1.1.2",
  "description": "CV generator life map frontend",
  "keywords": [
    "CV generator"
  ],
  "author": "Georgi Marinov",
  "homepage": "https://yrkki.github.io/cv-generator-life-map/",
  "license": "Apache-2.0",
  "scripts": {
    "ng": "ng",
    "start": "node server.js",
    "serve": "ng serve",
    "live": "nodemon server.js",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "buildfast": "ng build --stats-json --source-map=false",
    "heroku-postbuild": "npm run build",
    "test": "snyk test && ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "snyk-protect": "snyk-protect",
    "prepare": "npm run snyk-protect",
    "dev:plan:update:report:action:update-packages": "npm-run-all update-packages:*",
    "update-packages:install": "npm install --legacy-peer-deps",
    "update-packages:ng-update": "ng update",
    "update-packages:npx-npm-check-updates-u": "npx npm-check-updates --timeout 600000 -u --packageFile package.json && npm install --legacy-peer-deps",
    "open": "npm run open:local",
    "open:remote": "node server.js -o https://cv-generator-life-map.herokuapp.com/",
    "open:local": "ng serve --open=true"
  },
  "main": "src/main.ts",
  "private": false,
  "release": {
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "angular",
          "parserOpts": {
            "noteKeywords": [
              "BREAKING CHANGE",
              "BREAKING CHANGES",
              "BREAKING"
            ]
          }
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "angular",
          "parserOpts": {
            "noteKeywords": [
              "BREAKING CHANGE",
              "BREAKING CHANGES",
              "BREAKING"
            ]
          },
          "writerOpts": {
            "commitsSort": [
              "scope",
              "subject"
            ]
          }
        }
      ],
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/changelog",
      "@semantic-release/git"
    ],
    "branches": [
      "master"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Yrkki/cv-generator-life-map.git"
  },
  "overrides": {
    "@opentelemetry/api": "1.9.0",
    "nopt": "^9",
    "@npmcli/installed-package-contents": "^4",
    "rimraf": "^6",
    "uuid": "^9",
    "glob": "^10",
    "boom": "@hapi/boom",
    "cryptiles": "@hapi/cryptiles",
    "sntp": "@hapi/sntp",
    "hoek": "@hapi/hoek",
    "hawk": "@hapi/hawk",
    "inflight": "1.0.6",
    "request": "^2.88.2",
    "oclif": "^4"
  },
  "dependencies": {
    "@angular/animations": "^22.0.7",
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "@angular/platform-browser-dynamic": "^22.0.7",
    "@angular/platform-server": "^22.0.7",
    "@angular/pwa": "^22.0.7",
    "@angular/router": "^22.0.7",
    "@angular/service-worker": "^22.0.7",
    "@snyk/protect": "^1.1306.1",
    "@tailorbrands/node-exporter-prometheus": "2.0.7",
    "angular-plotly.js": "20.0.0",
    "bootstrap": "^4.6.2",
    "compression": "1.8.1",
    "express": "5.2.1",
    "newrelic": "^14.3.0",
    "npm-run-all": "4.1.5",
    "plotly.js": "^3.7.0",
    "rxjs": "^7.8.2",
    "spdy": "^4.0.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.7",
    "@angular-devkit/core": "^22.0.7",
    "@angular-devkit/schematics": "^22.0.7",
    "@angular-eslint/builder": "^22.1.0",
    "@angular-eslint/eslint-plugin": "^22.1.0",
    "@angular-eslint/eslint-plugin-template": "^22.1.0",
    "@angular-eslint/schematics": "^22.1.0",
    "@angular-eslint/template-parser": "^22.1.0",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@angular/language-service": "^22.0.7",
    "@compodoc/compodoc": "2.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@szmarczak/http-timer": "5.0.1",
    "@types/jasmine": "6.0.0",
    "@types/jasminewd2": "2.0.13",
    "@types/node": "26.1.1",
    "@types/plotly.js": "^3.0.10",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "@vitest/browser-playwright": "^4.1.10",
    "auto-changelog": "2.6.0",
    "codecov": "^3.8.3",
    "conventional-changelog-angular": "^9.2.1",
    "coveralls": "3.1.1",
    "enhanced-resolve": "5.24.2",
    "eslint": "^9.39.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "63.1.0",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "figlet": "^1.11.2",
    "figlet-cli": "^0.3.0",
    "jasmine-spec-reporter": "^7.0.0",
    "jsdom": "^29.1.1",
    "karma-htmlfile-reporter": "^0.3.8",
    "lighthouse": "^13.4.0",
    "protractor": "^7.0.0",
    "sass": "^1.101.0",
    "semantic-release": "^25.0.8",
    "ts-node": "10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.0.0 <25",
    "npm": ">=10.0.0 <12"
  },
  "snyk": true
}
